{
  "project": "Sekrt – SFTP Dashboard",
  "version": "1.0.0",

  "colors": {
    "background": {
      "default": "#fcfcfc",
      "card": "#ffffff",
      "muted": "#f6f8fa",
      "subtle": "#f1f1f1",
      "avatar": "#f1f1ef"
    },
    "border": {
      "default": "#eeeff1",
      "subtle": "#f4f4f4",
      "divider": "#ebebea",
      "row": "rgba(0,0,0,0.06)"
    },
    "text": {
      "primary": "#1a1a1a",
      "secondary": "#2a2a2a",
      "muted": "#9b9a97",
      "placeholder": "#7e7e7e",
      "emphasis": "#25292e"
    },
    "brand": {
      "primary": "#6e5fd8",
      "dark": "#25292e"
    },
    "status": {
      "danger": {
        "text": "#c10007",
        "background": "#ffebe9"
      },
      "warning": {
        "text": "#bb4d00",
        "background": "#fff8c5"
      },
      "success": {
        "text": "#008236"
      },
      "connected": {
        "text": "#6e5fd8"
      }
    },
    "avatar": {
      "purple": "#6e5fd8",
      "teal": "#14b8a6",
      "orange": "#f97316"
    }
  },

  "typography": {
    "fontFamilies": {
      "sans": "Google Sans",
      "mono": "Menlo",
      "alt": "Inter"
    },
    "fontSizes": {
      "xs": "10px",
      "sm": "11px",
      "base": "12px",
      "md": "13px",
      "lg": "14px",
      "xl": "20px",
      "brand": "21.02px",
      "display": "28px"
    },
    "fontWeights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600
    },
    "lineHeights": {
      "tight": "16px",
      "base": "16.5px",
      "md": "17.875px",
      "body": "19.5px",
      "lg": "20px",
      "xl": "28px",
      "display": "32px"
    },
    "letterSpacing": {
      "tight": "-0.3172px",
      "base": "-0.0762px",
      "brand": "-0.2102px",
      "caption": "0.0645px",
      "heading": "-0.24px"
    }
  },

  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "10px",
    "4": "12px",
    "5": "16px",
    "6": "24px",
    "7": "32px",
    "8": "35px"
  },

  "borderRadius": {
    "sm": "6px",
    "md": "8px",
    "lg": "10px",
    "xl": "30px",
    "pill": "100px"
  },

  "shadows": {
    "card": "0px 0.5px 5px rgba(31,35,40,0.05)"
  },

  "components": {
    "sidebar": {
      "width": "228px",
      "background": "#fcfcfc",
      "border": "#f4f4f4",
      "navItem": {
        "activeBackground": "#f1f1f1",
        "inactiveBackground": "#fcfcfc",
        "borderRadius": "8px",
        "padding": "4px"
      }
    },
    "card": {
      "background": "#ffffff",
      "border": "#eeeff1",
      "borderRadius": "10px",
      "padding": "16px"
    },
    "button": {
      "primary": {
        "background": "#25292e",
        "text": "#f6f8fa",
        "border": "#f7f7f7"
      },
      "secondary": {
        "background": "#ffffff",
        "text": "#25292e",
        "border": "#e4e1e1"
      },
      "borderRadius": "8px",
      "paddingX": "12px",
      "paddingY": "4px"
    },
    "badge": {
      "borderRadius": "100px",
      "paddingX": "7px",
      "paddingY": "1px"
    },
    "avatar": {
      "size": "28px",
      "borderRadius": "8px",
      "textColor": "#ffffff",
      "fontSize": "11px"
    }
  }
}
